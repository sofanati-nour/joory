{
  "name": "@app/api",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "db:generate": "bun ./node_modules/.bin/drizzle-kit generate",
    "db:migrate": "bun ./node_modules/.bin/drizzle-kit migrate",
    "db:push": "bun ./node_modules/.bin/drizzle-kit push",
    "db:studio": "bun ./node_modules/.bin/drizzle-kit studio",
    "cleanup:empty-chats": "bun run src/scripts/cleanup-empty-chats.ts",
    "cleanup:empty-chats:dry": "bun run src/scripts/cleanup-empty-chats.ts --dry-run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.44.0",
    "fast-xml-parser": "^5.5.3",
    "hono": "^4.12.0",
    "nanoid": "^5.1.6",
    "postgres": "^3.4.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9"
  }
}
