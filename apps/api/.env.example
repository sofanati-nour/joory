DATABASE_URL=postgresql://user:password@localhost:5432/joory
OPENROUTER_API_KEY=sk-or-your-api-key
BETTER_AUTH_SECRET=your-secret-minimum-32-characters-long

# URL this API is reachable at — must be https:// in production
BETTER_AUTH_URL=http://localhost:3001

# Comma-separated list of allowed cross-origin URLs.
# In development, falls back to http://localhost:5173,http://localhost:4173.
# REQUIRED in production — omitting it will block all cross-origin requests.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional — only required to enable Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

PORT=3001
NODE_ENV=development
