# ============================================================
# Joory — Caddyfile
#
# Caddy automatically provisions & renews TLS certificates
# via Let's Encrypt / ZeroSSL.
# ============================================================

# ---- API subdomain → api container ----
api.joory.chat {
	reverse_proxy api:3001
}

# ---- Main domain → SvelteKit web container ----
joory.chat {
	reverse_proxy web:3000
}
