# ============================================================
# Joory — Production Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.production.example .env
# ============================================================

# ---- Public URL the frontend uses to reach the API ----
PUBLIC_API_BASE=https://api.joory.chat

# ---- Better Auth ----
BETTER_AUTH_URL=https://api.joory.chat
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars

# ---- Allowed origins (CORS) ----
ALLOWED_ORIGINS=https://joory.chat

# ---- Database ----
POSTGRES_USER=joory
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=joory

# ---- OpenRouter ----
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ---- Google OAuth (optional — remove or leave empty to disable) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
